# API Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/momentum
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# AI Coaching
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Payments (Flutterwave)
NEXT_PUBLIC_FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx-X
FLW_PUBLIC_KEY=FLWPUBK_TEST-xxxxxxxx-X
FLW_SECRET_KEY=FLWSECK_TEST-xxxxxxxx-X
FLW_ENCRYPTION_KEY=FLWSECK_TEST_xxxxxxxx
FLW_SECRET_HASH=momentum_secret_hash

# Supabase (Admin - for server-side operations)
# Get this from your Supabase Dashboard -> Settings -> API -> service_role key
# Required for: updating user metadata after payment verification, admin operations
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Email (SMTP / Nodemailer)
# Leave SMTP_* empty to use Ethereal (captures emails in browser for dev)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=your-email@gmail.com
EMAIL_FROM_NAME=Momentum

# Push Notifications
FCM_SERVER_KEY=your_fcm_server_key_here

# File Uploads
CLOUDINARY_URL=your_cloudinary_url_here
